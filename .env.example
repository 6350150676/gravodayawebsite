# Site URL — used for the sitemap, robots.txt, canonical/OG tags, and links in
# email notifications. Set to your production domain when deploying.
NEXT_PUBLIC_SITE_URL=https://www.garvodayrealty.com

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend (email notifications)
RESEND_API_KEY=

# WhatsApp team notifications (Meta WhatsApp Cloud API).
# Leave blank to disable. Full setup guide: docs/whatsapp-notifications.md
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Comma-separated team numbers WITH country code, digits only, e.g. 919876543210,919812345678
WHATSAPP_TEAM_NUMBERS=
# Approved template name/language in Meta Business Manager (defaults shown)
WHATSAPP_TEMPLATE_NAME=new_inquiry
WHATSAPP_TEMPLATE_LANG=en

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# AI chat search — the parser tries GROQ first, then GEMINI, then a free
# keyword fallback. Set at least one for smart natural-language search.
#
# Groq: free, NO credit card. Get a key at https://console.groq.com/keys
GROQ_API_KEY=
# Gemini: free tier is region-limited; enabling billing removes the free tier.
# Key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Upstash Redis (rate limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Meta (Facebook) Pixel — leave blank to disable tracking
NEXT_PUBLIC_META_PIXEL_ID=
